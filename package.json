{
  "name": "@s1m0n38/pi-voice",
  "version": "2.0.1",
  "description": "HTTP server for Kokoro TTS — text-to-speech via ONNX inference.",
  "type": "module",
  "license": "MIT",
  "author": "S1M0N38",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "tts",
    "kokoro",
    "speech-synthesis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/S1M0N38/pi-voice"
  },
  "bin": {
    "pi-voice": "./bin/pi-voice.mjs"
  },
  "files": [
    "bin",
    "extensions",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "!.github"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --import jiti extensions/server.test.ts",
    "test:tui": "bash tests/tui.sh",
    "test:toggle": "bash tests/toggle.sh",
    "test:queue": "bash tests/queue.sh",
    "test:e2e": "bash tests/run.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "cli": "node --import jiti src/cli.ts",
    "server": "node --import jiti extensions/server.ts",
    "prepare": "node --import jiti src/prepare.js"
  },
  "dependencies": {
    "jiti": "^2.4.2",
    "kokoro-js": "^1.2.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@mariozechner/pi-coding-agent": "^0.70.0",
    "typebox": "^1.1.24",
    "typescript": "^5.0.0"
  }
}
